#!/usr/bin/env bash

# `.external` handles all external tools.
#
# This file is used as a part of `.zshrc`

# Cache directory for tool init scripts (avoids forking on every shell open)
_cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}/shell-init"
[ -d "$_cache_dir" ] || mkdir -p "$_cache_dir"

# Helper: cache an init command's output and source it
# Usage: _cached_init <name> <command> [args...]
# Regenerate cache: rm ~/.cache/shell-init/<name>.zsh && reload
_cached_init() {
  local name="$1"; shift
  local cache="$_cache_dir/$name.zsh"
  if [ ! -f "$cache" ]; then
    "$@" > "$cache" 2>/dev/null
  fi
  source "$cache"
}

# === fzf ===
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh
export FZF_DEFAULT_OPTS='--height=40% --preview="cat {}" --preview-window=right:60%:wrap'

# === zoxide ===
_cached_init zoxide zoxide init zsh

# === mise (unified version manager - replaces asdf + nvm) ===
# Using --shims for fast startup (~0s vs ~8s for full activate)
command -v mise &> /dev/null && _cached_init mise mise activate zsh --shims

# === direnv ===
command -v direnv &> /dev/null && _cached_init direnv direnv hook zsh

# === atuin (enhanced shell history with fuzzy search) ===
if command -v atuin &> /dev/null; then
  export ATUIN_NOBIND=true
  _cached_init atuin atuin init zsh --disable-up-arrow
fi

# === kiro ===
[[ "$TERM_PROGRAM" == "kiro" ]] && . "$(kiro --locate-shell-integration-path zsh)"

unset _cache_dir
