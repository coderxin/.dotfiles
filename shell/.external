#!/usr/bin/env bash

# `.external` handles all external tools.
#
# This file is used as a part of `.zshrc`


# === fzf ===
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh
export FZF_DEFAULT_OPTS='--height=40% --preview="cat {}" --preview-window=right:60%:wrap'

# === zoxide ===
eval "$(zoxide init zsh)"

# === mise (unified version manager - replaces asdf + nvm) ===
command -v mise &> /dev/null && eval "$(mise activate zsh)"

# === asdf (legacy fallback - migrate tools to mise to remove this) ===
[ -f /usr/local/opt/asdf/libexec/asdf.sh ] && . /usr/local/opt/asdf/libexec/asdf.sh

# === direnv ===
command -v direnv &> /dev/null && eval "$(direnv hook zsh)"

# === nvm (legacy fallback - migrate to mise to remove this) ===
export NVM_DIR="$HOME/.nvm"
[ -s "/usr/local/opt/nvm/nvm.sh" ] && \. "/usr/local/opt/nvm/nvm.sh"
[ -s "/usr/local/opt/nvm/etc/bash_completion.d/nvm" ] && \. "/usr/local/opt/nvm/etc/bash_completion.d/nvm"

# === atuin (enhanced shell history with fuzzy search + optional cross-machine sync) ===
# Run `atuin register` or `atuin login` to enable sync
command -v atuin &> /dev/null && eval "$(atuin init zsh --disable-up-arrow)"

# === kiro ===
[[ "$TERM_PROGRAM" == "kiro" ]] && . "$(kiro --locate-shell-integration-path zsh)"
