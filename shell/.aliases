#!/usr/bin/env bash

# `.aliases` is used to provide custom variables.
#
# This file is used as a part of `.zshrc`

# === Aliases ===

# reload shell
alias reload='. ~/.zshrc'

# another way to exit
alias quit='exit'

# bat styling
alias bat="\bat --theme=GitHub"

# using bat instead of cat
alias cat="\bat"

# git aliases
alias g='git'
alias gm='git merge'
alias gp='git pull --rebase'
alias gpsh='git push'
alias gpu='git push origin'
alias gd='git diff'
alias gds='git diff --stat'
alias gdc='git diff --cached'
alias gdcs='git diff --cached --stat'
alias gc='git commit'
alias gci='git commit'
alias gco='git checkout'
alias gb='git branch'
alias gs='git status'
alias gst='git status'
alias gl='git log --graph --pretty=format:"%C(yellow)%h%Creset %C(cyan)%d%Creset %s %C(dim white)(%cr) %C(blue)<%an>%Creset" --all'
alias gll='git log --graph --pretty=format:"%C(yellow bold)%h%Creset by %C(red)%an%Creset (%ar)%C(cyan bold)%d%Creset%n%s%n%b" --all'
alias glog='git log --graph --abbrev-commit --decorate --format=format:"%C(bold blue)%h%C(reset) - %C(bold cyan)%aD%C(reset) %C(bold green)(%ar)%C(reset)%C(bold yellow)%d%C(reset)%n          %C(white)%s%C(reset) %C(dim white)- %an%C(reset)" --all'

# Solution to allow Lazygit to work with Nvim (https://github.com/kdheepak/lazygit.nvim/issues/67#issuecomment-1307774937)
alias vim="nvim --listen /tmp/nvim-server.pipe"

# Navigation
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias -- -='cd -'

# Better listing (requires eza)
alias ls='eza --icons'
alias ll='eza -la --icons --git'
alias lt='eza --tree --icons --level=2'
alias llt='eza --tree --icons --level=3 -la'

# Safety nets
alias rm='rm -i'
alias cp='cp -i'
alias mv='mv -i'
alias mkdir='mkdir -p'

# Network
alias myip='curl -s ifconfig.me'
alias flushdns='sudo dscacheutil -flushcache && sudo killall -HUP mDNSResponder'
alias headers='curl -I'

# System / macOS
alias update='brew update && brew upgrade'
alias cleanup='find . -name ".DS_Store" -delete'
alias lock='/System/Library/CoreServices/Menu\ Extras/User.menu/Contents/Resources/CGSession -suspend'
alias top='btop'

# Development
alias py='python3'
alias pip='pip3'
alias serve='python3 -m http.server 8000'
alias json='python3 -m json.tool'
alias path='echo $PATH | tr ":" "\n"'

# Clipboard
alias copy='pbcopy'
alias paste='pbpaste'

# Show local IP
alias localip="ipconfig getifaddr en0"

# Copy public key to clipboard
alias pubkey="cat ~/.ssh/id_rsa.pub | pbcopy | echo '=> Public key copied to pasteboard.'"

# Open ports
alias oports="sudo lsof -i -n -P | grep TCP"

# Tmux / Tmuxinator aliases
alias mux='tmuxinator'
alias muxr='tmuxinator start rails'
alias muxrs='tmuxinator start rust'
alias muxn='tmuxinator start node'
alias muxk='tmuxinator start k8s'
alias muxp='tmuxinator start project'
alias tp='tmux-project'

# Zellij aliases
alias zj='zellij'
alias zja='zellij attach'
alias zjl='zellij list-sessions'
alias zjk='zellij kill-session'
alias zjka='zellij kill-all-sessions'
alias zjd='zellij delete-session'
alias zjda='zellij delete-all-sessions'
alias zjn='zellij-layout node'
alias zjr='zellij-layout rails'
alias zjrs='zellij-layout rust'
alias zjk8='zellij-layout k8s'
alias zjp='zellij-project'

# Claude
alias cly='claude --dangerously-skip-permissions'
